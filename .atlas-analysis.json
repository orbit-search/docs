  "keyFeatures": [
    "Natural language smart search over millions of professional profiles",
    "Scoped search: global, team-based, or custom directory corpora",
    "AI-powered query routing with structured, semantic, and agentic tiers",
    "Developer API keys with fine-grained scopes and credit metering",
    "CSV upload and connection import for custom searchable directories",
    "Organization and team access management for enterprise workloads",
    "Profile read API returning a safe, allowlisted public DTO",
    "Idempotent requests and safe credit refunds on failures"
  ],
