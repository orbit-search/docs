{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Orbit Search",
  "description": "Developer documentation for the Orbit Search API, API keys, directories, credits, and profile search workflows.",
  "theme": "luma",
  "logo": {
    "light": "/assets/orbit-logo-mark.png",
    "dark": "/assets/orbit-logo-mark.png",
    "href": "https://developer.orbitsearch.com"
  },
  "favicon": "/assets/icon.png",
  "metadata": {
    "og:image": "/assets/opengraph-image.jpg"
  },
  "colors": {
    "primary": "#3AB3FF",
    "light": "#3AB3FF",
    "dark": "#3AB3FF"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#FAFAFA",
      "dark": "#00050E"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "dark"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://orbitsearch.com"
      },
      {
        "label": "Dashboard",
        "href": "https://developer.orbitsearch.com/dashboard"
      },
      {
        "type": "github",
        "href": "https://github.com/orbit-search"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://developer.orbitsearch.com/auth/signup?next=%2Fdashboard%2Fkeys"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/search",
              "concepts/directories",
              "concepts/organizations",
              "concepts/credits"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/first-search",
              "guides/directory-setup",
              "guides/key-rotation",
              "guides/error-handling"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Search",
            "pages": [
              "api/search/smart-search",
              "api/search/deep-search",
              "api/search/profile-read"
            ]
          },
          {
            "group": "Keys",
            "pages": [
              "api/api-keys/create",
              "api/api-keys/list",
              "api/api-keys/revoke",
              "api/api-keys/usage"
            ]
          },
          {
            "group": "Directories",
            "pages": [
              "api/directories/manage",
              "api/directories/sources",
              "api/directories/grants"
            ]
          },
          {
            "group": "Organizations",
            "pages": [
              "api/organizations/overview",
              "api/organizations/directory-access"
            ]
          }
        ]
      }
    ]
  }
}
